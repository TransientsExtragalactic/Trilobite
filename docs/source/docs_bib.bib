@article{piroLatetimeEvolutionInstabilities2025,
	title = {Late-time {Evolution} and {Instabilities} of {Tidal} {Disruption} {Disks}},
	volume = {985},
	issn = {0004-637X},
	url = {https://ui.adsabs.harvard.edu/abs/2025ApJ...985...77P},
	doi = {10.3847/1538-4357/adc729},
	abstract = {Observations of tidal disruption events on timescales of years after the main flare show evidence of continued activity in the form of optical/UV emission, quasiperiodic eruptions, and delayed radio flares. Motivated by this, we explore the time evolution of these disks, using semi-analytic models to follow the changing disk properties and feeding rate to the central black hole. We find that thermal instabilities typically begin ∼100 days after the TDE, causing the disk to cycle between high and low accretion states for up to ∼10 yr. The high state is super-Eddington, which may be associated with outflows that eject ∼10−3─10−1 M⊙ over ∼1─2 days, with a range of velocities ∼0.03─0.3c. Collisions between these mass ejections may cause radio flares. In the low state, the accretion rate slowly grows over months to years, as continued fallback accretion builds the disk's mass. In this phase, the disk has a luminosity of ∼1041─1042 erg s−1 in the optical/UV, as seen in some late-time observations. Although the accretion cycles we find occur for a typical α-disk, in nature, the disk could be stabilized by other effects, such as the disk's magnetic field or heating from fallback accretion, the latter of which we explore. Thus, higher-cadence optical/UV observations along with joint radio monitoring will be key for following the disk state and testing these models.},
	urldate = {2026-04-14},
	journal = {The Astrophysical Journal},
	publisher = {IOP},
	author = {Piro, Anthony L. and Mockler, Brenna},
	month = may,
	year = {2025},
	note = {ADS Bibcode: 2025ApJ...985...77P},
	keywords = {High Energy Astrophysical Phenomena, 1696, Tidal disruption, 1663, Supermassive black holes, 14, 1851, Accretion, Transient sources},
	pages = {77},
}

@article{wataraiNewAnalyticalFormulae2006,
	title = {New {Analytical} {Formulae} for {Supercritical} {Accretion} {Flows}},
	volume = {648},
	issn = {0004-637X},
	url = {https://ui.adsabs.harvard.edu/abs/2006ApJ...648..523W},
	doi = {10.1086/505854},
	abstract = {We examine a new family of global analytic solutions for optically thick accretion disks, which includes the supercritical accretion regime. We found that the ratio of the advection cooling rate, Qadv, to the viscous heating rate, Qvis, i.e., f=Qadv/Qvis, can be represented by an analytical form dependent on the radius and the mass accretion rate. The new analytic solutions can be characterized by the photon-trapping radius, rtrap, inside which the accretion time is less than the photon diffusion time in the vertical direction; the nature of the solutions changes significantly as this radius is crossed. Inside the trapping radius, f approaches f{\textasciitilde}r0, which corresponds to the advection-dominated limit (f{\textasciitilde}1), whereas outside the trapping radius, the radial dependence of f changes to f{\textasciitilde}r-2, which corresponds to the radiative-cooling-dominated limit. The analytical formula for f derived here smoothly connects these two regimes. The set of new analytic solutions reproduces well the global disk structure obtained by numerical integration over a wide range of mass accretion rates, including the supercritical accretion regime. In particular, the effective temperature profiles for our new solutions are in good agreement with those obtained from numerical solutions. Therefore, the new solutions will provide a useful tool not only for evaluating the observational properties of accretion flows, but also for investigating the mass evolution of black holes in the presence of supercritical accretion flows.},
	urldate = {2026-04-14},
	journal = {The Astrophysical Journal},
	publisher = {IOP},
	author = {Watarai, Ken-ya},
	month = sep,
	year = {2006},
	note = {ADS Bibcode: 2006ApJ...648..523W},
	keywords = {Accretion, Accretion Disks, Astrophysics, Black Hole Physics, X-Rays: Stars},
	pages = {523--533},
	file = {Submitted Version:/Users/ediggins/Zotero/storage/WQAHNZBF/Watarai - 2006 - New Analytical Formulae for Supercritical Accretion Flows.pdf:application/pdf},
}

@article{begelmanCanSphericallyAccreting1979,
	title = {Can a spherically accreting black hole radiate very near the {Eddington} limit?},
	volume = {187},
	issn = {0035-8711},
	url = {https://ui.adsabs.harvard.edu/abs/1979MNRAS.187..237B},
	doi = {10.1093/mnras/187.2.237},
	abstract = {Some aspects of radiative transfer through a supercritical spherically symmetric accretion flow onto a black hole are discussed, and it is concluded that the diffusive luminosity at infinity cannot exceed 0.6 times the Eddington limit for a gas of Thomson scatterers (LE). All of the emergent radiation is produced by the gas during infall from energy originally supplied by the gravitational field. When the gas has fallen far enough for its emissivity to approach LE, it is on the verge of crossing the 'trapping radius' for radiation, and much of the radiation is dragged into the hole. On the basis of this result, it is argued that radiation pressure from a spherically accreting black hole cannot prevent the accretion rate from attaining arbitrarily high values, even if 'photon bubbles' transport much of the radiation. The possible astrophysical relevance of supercritically accreting black holes and the possible appearance of such a black hole to an observer are discussed.},
	urldate = {2026-04-14},
	journal = {Monthly Notices of the Royal Astronomical Society},
	publisher = {OUP},
	author = {Begelman, M. C.},
	month = apr,
	year = {1979},
	note = {ADS Bibcode: 1979MNRAS.187..237B},
	keywords = {Astrophysics, Black Holes (Astronomy), Radiative Transfer, Accretion:Black Holes, Dissipation, Flow Distribution, Radiation Pressure, Radiation Sources, Spheres, Stellar Mass Accretion, Supercritical Flow, Thomson Scattering},
	pages = {237--251},
}

